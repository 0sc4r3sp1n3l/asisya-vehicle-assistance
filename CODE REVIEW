No hay validaciones
Hallazgo
No se validan parámetros de entrada.
Riesgo
Datos inválidos en base.
Solución
Usar FluentValidation:
public class OptimizeCommandValidator 
    : AbstractValidator<OptimizeProviderCommand>
{
    public OptimizeCommandValidator()
    {
        RuleFor(x => x.Latitude)
            .InclusiveBetween(-90, 90);

        RuleFor(x => x.Longitude)
            .InclusiveBetween(-180, 180);

        RuleFor(x => x.AssistanceType)
            .NotEmpty();
    }
}
